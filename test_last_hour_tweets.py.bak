# 临时修改导入的函数
import asyncio
import json
from datetime import datetime, timezone, timedelta
from playwright.async_api import async_playwright

AUTH_TOKEN = os.getenv('TWITTER_AUTH_TOKEN', '5da5c73c3286e0c825c5a337eb60ffaf93f2620c')
CT0 = os.getenv('TWITTER_CT0', 'bb867bfa8ae5a410dec9e6537f8aa4f183c43b65c641f9b293a171e8eb8b1b9df359891c89b0e181f4c21bb6e292f422075b77ac3f51a0915fc5e82e2c69c9c5100c14355137082faa36804f10f18ebd')

MONITOR_ACCOUNTS = {
    'elonmusk': 'Elon Musk',
    'jdhasoptions': 'jdhasoptions', 
    'xiaomucrypto': 'xiaomucrypto',
    'aistocksavvy': 'AI Stock Savvy',
    'BlueJay87476298': 'BlueJay'
}

def translate_text(text):
    """翻译文本"""
    if not text:
        return ""
    if any('\u4e00' <= char <= '\u9fff' for char in text[:100]):
        return text
    try:
        import urllib.request
        import urllib.parse
        encoded_text = urllib.parse.quote(text[:500])
        url = f"https://api.mymemory.translated.net/get?q={encoded_text}&langpair=en|zh"
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        with urllib.request.urlopen(req, timeout=10) as response:
            data = json.loads(response.read())
            if data.get('responseStatus') == 200:
                return data.get('responseData', {}).get('translatedText', text)
    except:
        pass
    return text[:150] + "...[待翻译]" if len(text) > 150 else text + "[待翻译]"

def get_time_ago(time_str):
    """计算相对时间"""
    try:
        tweet_time = datetime.fromisoformat(time_str.replace('Z', '+00:00'))
        now = datetime.now(timezone.utc)
        diff = now - tweet_time
        if diff.days > 0:
            return f"{diff.days}天前"
        hours = diff.seconds // 3600
        if hours > 0:
            return f"{hours}小时前"
        minutes = (diff.seconds % 3600) // 60
        return f"{minutes}分钟前"
    except:
        return "未知"

async def fetch_user_tweets_last_hour(username, name, max_hours=1):
    """抓取最近N小时的推文"""
    async with async_playwright() as p:
        browser = await p.chromium.launch(headless=True, args=['--no-sandbox'])
        context = await browser.new_context(viewport={'width': 1920, 'height': 1080})
        
        await context.add_cookies([
            {'name': 'auth_token', 'value': AUTH_TOKEN, 'domain': '.x.com', 'path': '/'},
            {'name': 'ct0', 'value': CT0, 'domain': '.x.com', 'path': '/'}
        ])
        
        page = await context.new_page()
        
        try:
            print(f"  正在抓取 @{username}...")
            await page.goto(f'https://x.com/{username}', timeout=30000)
            await asyncio.sleep(5)
            
            tweets_data = []
            tweets = await page.query_selector_all('[data-testid="tweet"]')
            print(f"  找到 {len(tweets)} 条推文")
            
            for tweet in tweets[:5]:  # 取前5条
                try:
                    text_elem = await tweet.query_selector('[data-testid="tweetText"]')
                    text = await text_elem.inner_text() if text_elem else ''
                    
                    time_elem = await tweet.query_selector('time')
                    time_str = await time_elem.get_attribute('datetime') if time_elem else ''
                    
                    # 检查是否在指定小时内
                    try:
                        tweet_time = datetime.fromisoformat(time_str.replace('Z', '+00:00'))
                        now = datetime.now(timezone.utc)
                        age_hours = (now - tweet_time).total_seconds() / 3600
                        
                        if age_hours > max_hours:
                            continue  # 跳过太旧的
                            
                    except:
                        continue
                    
                    # 获取tweet_id
                    tweet_id = ''
                    try:
                        link_elem = await tweet.query_selector('a[href*="/status/"]')
                        if link_elem:
                            href = await link_elem.get_attribute('href')
                            if href and '/status/' in href:
                                tweet_id = href.split('/status/')[-1].split('?')[0]
                    except:
                        pass
                    
                    tweet_url = f'https://x.com/{username}/status/{tweet_id}' if tweet_id else f'https://x.com/{username}'
                    
                    tweets_data.append({
                        'author': username,
                        'name': name,
                        'text': text,
                        'translate': translate_text(text),
                        'time': time_str,
                        'time_ago': get_time_ago(time_str),
                        'hours_ago': round(age_hours, 1),
                        'tweet_id': tweet_id,
                        'url': tweet_url,
                        'captured_at': datetime.now().isoformat()
                    })
                except Exception as e:
                    continue
            
            await browser.close()
            return tweets_data
            
        except Exception as e:
            print(f"  错误: {e}")
            await browser.close()
            return []

async def main():
    print("=" * 70)
    print("🐦 抓取最近1小时推文测试")
    print(f"⏰ 当前时间: {datetime.now().strftime('%H:%M:%S')}")
    print("=" * 70)
    
    all_tweets = []
    
    for username, name in MONITOR_ACCOUNTS.items():
        tweets = await fetch_user_tweets_last_hour(username, name, max_hours=1)
        if tweets:
            all_tweets.extend(tweets)
            print(f"  ✅ {name}: {len(tweets)} 条近1小时推文")
        else:
            print(f"  ⏭️  {name}: 无近1小时推文")
    
    print("\n" + "=" * 70)
    
    if all_tweets:
        # 按时间排序
        all_tweets.sort(key=lambda x: x.get('hours_ago', 999))
        
        print(f"📊 共找到 {len(all_tweets)} 条最近1小时推文\n")
        
        for i, t in enumerate(all_tweets, 1):
            print(f"\n{'='*70}")
            print(f"[{i}] {t['name']} (@{t['author']})")
            print(f"    发布时间: {t['time'][:19]} ({t['time_ago']})")
            print(f"    原文: {t['text'][:200]}")
            print(f"    翻译: {t['translate'][:150]}")
            print(f"    🔗 {t['url']}")
            print(f"{'='*70}")
    else:
        print("📭 最近1小时无新推文")
    
    print("\n" + "=" * 70)
    print("✅ 测试完成")
    print("=" * 70)

if __name__ == "__main__":
    asyncio.run(main())

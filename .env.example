# Lobster Workspace 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 警告: 永远不要将 .env 文件提交到Git!

# ==========================================
# Twitter API.io 配置 (必需)
# 申请地址: https://twitterapi.io/
# ==========================================
TWITTERAPI_IO_KEY=your_twitterapi_io_key_here

# ==========================================
# Twitter Cookie认证 (备用方案)
# 从浏览器开发者工具获取
# ==========================================
TWITTER_AUTH_TOKEN=your_auth_token_here
TWITTER_CT0=your_ct0_here

# ==========================================
# Alpha Vantage API (美股数据)
# 申请地址: https://www.alphavantage.co/support/#api-key
# ==========================================
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ==========================================
# NewsAPI (新闻数据)
# 申请地址: https://newsapi.org/
# ==========================================
NEWSAPI_KEY=your_newsapi_key_here

# ==========================================
# FRED API (美联储经济数据)
# 申请地址: https://fred.stlouisfed.org/docs/api/api_key.html
# ==========================================
FRED_API_KEY=your_fred_api_key_here

# ==========================================
# Telegram Bot (推送通知)
# ==========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ==========================================
# 数据库配置
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fund_manager
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ==========================================
# 其他API配置
# ==========================================
# OpenAI API (情感分析)
OPENAI_API_KEY=your_openai_key_here

# CoinGecko API (免费，无需Key)
COINGECKO_API_KEY=

# Etherscan API (以太坊数据)
ETHERSCAN_API_KEY=your_etherscan_key_here

# BSCScan API (BSC数据)
BSCSCAN_API_KEY=your_bscscan_key_here
